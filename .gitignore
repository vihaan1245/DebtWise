# ==========================================
# DebtWise - .gitignore
# ==========================================

# --- Environment & Secrets ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.*
instance/

# --- Backend (Python / Flask / SQLAlchemy) ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/
.tox/
.noseids
.venv
venv/
ENV/
env/
dist-backend/
*.db
*.sqlite
/migrations/versions/*.pyc

# --- Frontend (React / Vite / Node) ---
node_modules/
/frontend/node_modules/
dist/
/frontend/dist/
build/
/frontend/build/
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- IDEs, Editors & System ---
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
.DS_Store
Thumbs.db
Desktop.ini

# --- Logs & Temp ---
*.log
logs/
temp/
tmp/
